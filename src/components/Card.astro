---
import type { Item } from "../data/items";
import { itemUrl } from "../lib/catalog";
import Preview from "./Preview.astro";

export interface Props {
  item: Item;
}
const { item } = Astro.props;
const catLabel = item.cat.replace(/s$/, "");
---

<a class="card reveal" href={itemUrl(item)} data-slug={item.slug} aria-label={`${item.name} — view code`}>
  <div class="pv">
    <span class="heart" data-slug={item.slug} role="button" tabindex="-1" aria-label="Save to My Kit" title="Save to My Kit">♡</span>
    <Preview item={item} />
  </div>

  <div class="cb">
    <div>
      <div class="cn">{item.name}</div>
      <div class="cc">{catLabel}</div>
    </div>
    <span class="copen">&lt;/&gt; code</span>
  </div>
</a>
