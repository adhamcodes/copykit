---
import type { Item } from "../data/items";
import { frameDoc } from "../lib/codegen";
import { itemUrl } from "../lib/catalog";

export interface Props {
  item: Item;
}
const { item } = Astro.props;
const catLabel = item.cat.replace(/s$/, "");
---

<a class="card" href={itemUrl(item)} data-slug={item.slug} aria-label={`${item.name} — view code`}>
  <div class="pv">
    {item.type === "gradient" && <div style={`background:${item.grad}`}></div>}

    {item.type === "palette" && (
      <div class="pvpal">
        {item.cols.map((c) => (
          <div style={`background:${c}`}></div>
        ))}
      </div>
    )}

    {item.type === "shadow" && (
      <div class="pvshadow">
        <div
          class="pvcard"
          style={`box-shadow:${item.x}px ${item.y}px ${item.blur}px ${item.spread}px ${item.color}`}
        >
        </div>
      </div>
    )}

    {item.type === "comp" && (
      <iframe
        class="pvframe"
        loading="lazy"
        sandbox="allow-scripts"
        title={`${item.name} preview`}
        srcdoc={frameDoc(item, "#141021")}></iframe>
    )}
  </div>

  <div class="cb">
    <div>
      <div class="cn">{item.name}</div>
      <div class="cc">{catLabel}</div>
    </div>
    <span class="copen">&lt;/&gt; code</span>
  </div>
</a>
