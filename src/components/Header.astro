---
const GITHUB_URL = "https://github.com/adhamcodes/copykit";
---

<header>
  <nav class="wrap">
    <a class="logo" href="/" aria-label="CopyKit home">
      <span class="d"></span>
      <span>Copy<b>Kit</b></span>
    </a>
    <div class="search">
      <span class="mono" aria-hidden="true">⌕</span>
      <input
        type="search"
        placeholder="Search gradients, buttons, shadows…"
        aria-label="Search (coming soon)"
        disabled
      />
      <span class="k">/</span>
    </div>
    <div class="nav-actions">
      <a class="ghlink" href={GITHUB_URL} target="_blank" rel="noopener">GitHub</a>
      <span class="by">by Adham</span>
    </div>
  </nav>
</header>
