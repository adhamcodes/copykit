---
import { groupedCats, catUrl } from "../lib/catalog";
const GITHUB_URL = "https://github.com/adhamcodes/copykit";
const groups = groupedCats();
---

<footer>
  <div class="wrap">
    <div class="fcols">
      <div class="fbrand">
        <div class="logo"><span class="d"></span><span>Copy<b>Kit</b></span></div>
        <p>
          A living, copy-ready library of gradients, palettes, shadows and UI
          components. Free, no signup, 100% in your browser.
        </p>
        <div class="fsocial">
          <a href={GITHUB_URL} target="_blank" rel="noopener">GitHub</a>
          <button class="fsocial-btn" type="button" data-shortcuts>⌨ Shortcuts</button>
        </div>
      </div>
      <div class="flinks">
        {groups.map((g) => (
          <div class="fcol">
            <h4>{g.label}</h4>
            {g.cats.map((c) => (
              <a href={catUrl(c.meta.key)}>{c.meta.label}</a>
            ))}
          </div>
        ))}
      </div>
    </div>
    <div class="fbot">
      Made with care by <b>Adham</b> · <a href={GITHUB_URL} target="_blank" rel="noopener">CopyKit on GitHub</a> · press <kbd>?</kbd> for shortcuts
    </div>
  </div>
</footer>
